---
/**
 * Redesign-guarantee band. Reused on Process and Pricing. Reads site.guarantee.
 */
import { site } from "../../lib/site";
---

<section class="border-y border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="reveal mx-auto max-w-4xl px-6 py-16 text-center sm:py-20">
    <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)] px-4 py-1.5 text-xs font-semibold text-[var(--color-accent-text)]">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" />
      </svg>
      Our redesign guarantee
    </span>
    <h2 class="mt-5 text-2xl font-bold tracking-tight text-[var(--color-text)] sm:text-3xl">Love it, or you don't pay for the redesign.</h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-[var(--color-text-muted)]">{site.guarantee}</p>
    <p class="mt-3 text-sm text-[var(--color-text-subtle)]">We're a new studio — so we put the risk on us, not you.</p>
  </div>
</section>
