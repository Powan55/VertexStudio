---
/**
 * Home — hero + services + process + sample work + pricing teaser + FAQ teaser + CTA.
 * All content reads from site.ts (single source of truth).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/astro/Hero.astro";
import FinalCta from "../components/astro/FinalCta.astro";
import { site } from "../lib/site";
import { u } from "../lib/url";

const faqTeaser = [
  { q: "Who owns the site and code?", a: "You do — completely. Everything is yours." },
  { q: "How long does it take?", a: "Most projects launch in days, not months." },
  { q: "What if I don't like the design?", a: "We refine it until you do — that's our redesign guarantee." },
];
---

<BaseLayout meta={{ title: "Home", path: "/" }}>
  <Hero />

  <!-- Services -->
  <section class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="reveal max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl">What we build</h2>
      <p class="mt-3 text-lg text-[var(--color-text-muted)]">Three ways we get your business online and working harder.</p>
    </div>
    <div class="reveal mt-10 grid gap-6 sm:grid-cols-3">
      {site.services.map((s) => (
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition duration-200 hover:-translate-y-1 hover:border-[var(--color-text-subtle)]">
          <h3 class="text-lg font-semibold text-[var(--color-text)]">{s.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{s.blurb}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
      <div class="reveal max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl">How it works</h2>
        <p class="mt-3 text-lg text-[var(--color-text-muted)]">A clear, four-step path from idea to launch — no guesswork.</p>
      </div>
      <ol class="reveal mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {site.process.map((p) => (
          <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6">
            <span class="text-2xl font-bold text-[var(--color-accent-text)]" style="font-family:var(--font-display)">0{p.n}</span>
            <h3 class="mt-3 text-base font-semibold text-[var(--color-text)]">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{p.what}</p>
          </li>
        ))}
      </ol>
      <div class="reveal mt-8">
        <a href={u("/process")} class="text-sm font-semibold text-[var(--color-accent-text)] transition hover:text-[var(--color-accent-hover)]">See the full process →</a>
      </div>
    </div>
  </section>

  <!-- Sample work -->
  <section class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl">A look at how we work</h2>
        <p class="mt-3 text-lg text-[var(--color-text-muted)]">Two concept sites we designed to show our approach — invented businesses, real craft.</p>
      </div>
      <a href={u("/work")} class="text-sm font-semibold text-[var(--color-accent-text)] transition hover:text-[var(--color-accent-hover)]">See our work →</a>
    </div>
    <p class="reveal mt-3 text-sm text-[var(--color-text-subtle)]">Concept work — not actual clients.</p>
    <div class="reveal mt-8 grid gap-6 sm:grid-cols-2">
      {site.conceptDemos.map((d) => (
        <a
          href={u("/work")}
          class="group overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] transition duration-200 hover:-translate-y-1 hover:border-[var(--color-text-subtle)]"
        >
          <div class="relative aspect-[16/10] overflow-hidden" style={`background: linear-gradient(135deg, ${d.accent}26, var(--color-elevated));`}>
            <span class="absolute left-4 top-4 rounded-full bg-black/40 px-3 py-1 text-xs font-medium text-[var(--color-text)] backdrop-blur">
              Concept · {d.industry}
            </span>
            <span class="absolute inset-0 flex items-center justify-center text-2xl font-bold text-[var(--color-text-muted)]" style="font-family:var(--font-display)">
              {d.business}
            </span>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-semibold text-[var(--color-text)]">{d.business}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{d.outcome}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
      <div class="reveal max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl">Simple, honest pricing</h2>
        <p class="mt-3 text-lg text-[var(--color-text-muted)]">Three tiers to fit where your business is right now. Final price confirmed before any work begins.</p>
      </div>
      <div class="reveal mt-10 grid gap-6 md:grid-cols-3">
        {site.tiers.map((t) => (
          <div class={`relative rounded-2xl border p-6 ${t.popular ? "border-[var(--color-accent)]" : "border-[var(--color-border)]"} bg-[var(--color-bg)]`}>
            {t.popular && (
              <span class="absolute -top-3 left-6 rounded-full bg-[var(--color-accent)] px-3 py-1 text-xs font-semibold text-[var(--color-accent-fg)]">Most popular</span>
            )}
            <h3 class="text-lg font-semibold text-[var(--color-text)]">{t.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{t.positioning}</p>
            <p class="mt-4 text-sm font-semibold text-[var(--color-text)]">{t.priceFrom}</p>
          </div>
        ))}
      </div>
      <div class="reveal mt-8">
        <a href={u("/pricing")} class="text-sm font-semibold text-[var(--color-accent-text)] transition hover:text-[var(--color-accent-hover)]">See full pricing →</a>
      </div>
    </div>
  </section>

  <!-- FAQ teaser -->
  <section class="mx-auto max-w-3xl px-6 py-20 sm:py-24">
    <h2 class="reveal text-center text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl">Common questions</h2>
    <dl class="reveal mt-10 space-y-4">
      {faqTeaser.map((f) => (
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
          <dt class="font-semibold text-[var(--color-text)]">{f.q}</dt>
          <dd class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{f.a}</dd>
        </div>
      ))}
    </dl>
    <div class="reveal mt-8 text-center">
      <a href={u("/faq")} class="text-sm font-semibold text-[var(--color-accent-text)] transition hover:text-[var(--color-accent-hover)]">Read all FAQs →</a>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
