---
/**
 * Pricing — 4 build tiers ("starting at" floors) + a monthly care plan → request
 * form, plus "every project includes", the guarantee, and pricing FAQs.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import FinalCta from "../components/astro/FinalCta.astro";
import GuaranteeBand from "../components/astro/GuaranteeBand.astro";
import { site } from "../lib/site";

const meta = {
  title: "Pricing",
  description:
    "Straightforward website plans for every budget — plus an optional monthly care plan. Transparent pricing, no surprises, and you own everything we build.",
  path: "/pricing",
};

const includes = [
  { t: "Responsive", d: "Looks great on every phone, tablet, and screen." },
  { t: "Fast", d: "Built to load quickly so visitors don't bounce." },
  { t: "Accessible", d: "Usable by everyone, built to modern standards." },
  { t: "Yours", d: "You own the code, content, and domain. Always." },
];

const pricingFaqs = [
  { q: "Do you offer payment plans?", a: "We want the right website to be within reach, so we're happy to talk through payment options that work for your business. Ask us when you request a website and we'll find a fit." },
  { q: "How many revisions do I get?", a: "It depends on your plan — from two rounds on Starter up to unlimited within scope on Premium. And our redesign guarantee means we keep refining until you love the design." },
  { q: "Will there be extra costs I don't expect?", a: "No surprises — that's the rule. We confirm your full price before any work starts. The only ongoing costs are the everyday ones every website has, like domain renewal and hosting." },
  { q: "Can I upgrade later?", a: "Absolutely. Start with the plan that fits today, and add pages, features, or a store as your business grows. Since you own everything, you're never locked in." },
];
---

<BaseLayout meta={meta}>
  <section class="relative overflow-hidden bg-[var(--color-bg)]">
    <div class="glow pointer-events-none absolute inset-x-0 top-0 h-[420px]"></div>
    <div class="relative mx-auto max-w-3xl px-6 pt-20 pb-12 text-center sm:pt-24">
      <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text)] sm:text-5xl">Simple pricing, no surprises.</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-[var(--color-text-muted)]">
        Plans to match where your business is right now — from a single page to a full site. Every build is fast, built to convert, and built to be yours. The ranges below are starting points — we confirm your exact price before any work begins.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-8">
    <div class="grid items-stretch gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {site.tiers.map((t) => (
        <div class={`reveal relative flex flex-col rounded-2xl border p-6 sm:p-8 ${t.popular ? "border-[var(--color-accent)]" : "border-[var(--color-border)]"} bg-[var(--color-surface)]`}>
          {t.popular && (
            <span class="absolute -top-3 left-8 rounded-full bg-[var(--color-accent)] px-3 py-1 text-xs font-semibold text-[var(--color-accent-fg)]">Most popular</span>
          )}
          <h2 class="text-xl font-bold text-[var(--color-text)]">{t.name}</h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{t.positioning}</p>
          <p class="mt-5 text-lg font-bold text-[var(--color-text)]">{t.priceFrom}</p>
          <p class="text-xs text-[var(--color-text-subtle)]">Final price confirmed before any work begins.</p>
          <ul class="mt-6 flex-1 space-y-3 text-sm">
            {t.inclusions.map((i) => (
              <li class="flex gap-3 text-[var(--color-text-muted)]">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent-text)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
                <span>{i}</span>
              </li>
            ))}
          </ul>
          <a
            href={t.ctaHref}
            data-analytics="request_click"
            class={`mt-8 inline-flex min-h-[48px] items-center justify-center rounded-xl px-6 py-3 text-sm font-semibold transition ${t.popular ? "bg-[var(--color-accent)] text-[var(--color-accent-fg)] hover:bg-[var(--color-accent-hover)]" : "border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-text-subtle)]"}`}
          >
            {t.ctaLabel}
          </a>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-12">
    <div class="reveal relative flex flex-col rounded-2xl border border-[var(--color-accent)] bg-[var(--color-surface)] p-6 sm:p-8">
      <p class="text-sm font-semibold text-[var(--color-accent-text)]">Ongoing care &amp; support</p>
      <div class="mt-2 flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
        <h2 class="text-xl font-bold text-[var(--color-text)]">{site.carePlan.name}</h2>
        <p class="text-lg font-bold text-[var(--color-text)]">{site.carePlan.price} <span class="text-sm font-medium text-[var(--color-text-muted)]">{site.carePlan.cadence}</span></p>
      </div>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-text-muted)]">{site.carePlan.positioning}</p>
      <p class="mt-2 max-w-3xl text-sm font-medium text-[var(--color-text)]">{site.carePlan.attachModel}</p>
      <ul class="mt-6 grid gap-3 text-sm sm:grid-cols-2">
        {site.carePlan.inclusions.map((i) => (
          <li class="flex gap-3 text-[var(--color-text-muted)]">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent-text)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
            <span>{i}</span>
          </li>
        ))}
      </ul>
      <p class="mt-4 max-w-3xl text-xs leading-relaxed text-[var(--color-text-muted)]">{site.carePlan.excludesNote}</p>
      <a
        href={site.carePlan.ctaHref}
        data-analytics="request_click"
        class="mt-8 inline-flex min-h-[48px] items-center justify-center self-start rounded-xl bg-[var(--color-accent)] px-6 py-3 text-sm font-semibold text-[var(--color-accent-fg)] transition hover:bg-[var(--color-accent-hover)]"
      >
        {site.carePlan.ctaLabel}
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="reveal text-center text-2xl font-bold tracking-tight text-[var(--color-text)]">Every project includes</h2>
    <div class="reveal mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {includes.map((i) => (
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 text-center">
          <p class="font-semibold text-[var(--color-accent-text)]">{i.t}</p>
          <p class="mt-1 text-sm text-[var(--color-text-muted)]">{i.d}</p>
        </div>
      ))}
    </div>
  </section>

  <GuaranteeBand />

  <section class="mx-auto max-w-3xl px-6 py-20">
    <h2 class="reveal text-center text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl">Pricing questions</h2>
    <div class="reveal mt-8 space-y-3">
      {pricingFaqs.map((f) => (
        <details class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-[var(--color-text)] [&::-webkit-details-marker]:hidden">
            {f.q}
            <svg class="h-5 w-5 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <FinalCta headline="Not sure which plan fits? Just ask." body="Tell us about your business and we'll point you to the right starting place." />
</BaseLayout>
