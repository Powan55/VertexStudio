---
import BaseLayout from "../layouts/BaseLayout.astro";
import { u } from "../lib/url";
---

<BaseLayout meta={{ title: "Page not found", path: "/404", noindex: true }}>
  <section class="relative overflow-hidden">
    <div class="glow pointer-events-none absolute inset-x-0 top-0 h-[420px]"></div>
    <div class="relative mx-auto max-w-2xl px-6 py-28 text-center">
      <p class="text-6xl font-bold text-[var(--color-accent-text)]" style="font-family:var(--font-display)">404</p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl">This page took a wrong turn.</h1>
      <p class="mx-auto mt-4 max-w-md text-lg text-[var(--color-text-muted)]">
        The page you're looking for isn't here — maybe it moved, or the link had a typo. Let's get you back to somewhere useful.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={u("/")} class="inline-flex min-h-[48px] items-center justify-center rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-3 text-base font-semibold text-[var(--color-text)] transition hover:border-[var(--color-text-subtle)]">
          Back to home
        </a>
        <a href={u("/request")} data-analytics="request_click" class="inline-flex min-h-[48px] items-center justify-center rounded-xl bg-[var(--color-accent)] px-6 py-3 text-base font-semibold text-[var(--color-accent-fg)] transition hover:bg-[var(--color-accent-hover)]">
          Request a website
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
